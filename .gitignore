# =============================================================================
# ROOT .gitignore — Projects root
# =============================================================================

# ── Browser Profile History (contains cached API keys & secrets) ─────────────
# AdsPower browser profiles store browsing history with embedded tokens
**/User/History/
**/profiles/*/User/History/
**/main_script/profiles/*/User/History/

# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.secret

# ── Backup credentials (contains encryption passwords) ───────────────────────
VPS_BACKUP_README.txt
BACKUP_PASSWORD_README.txt
*_password.txt

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
venv_local/
env/
*.egg-info/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Build artifacts ──────────────────────────────────────────────────────────
build/
dist/
*.egg

# ── Unrelated projects (moved out of monorepo) ───────────────────────────────
first-shot-website/
debuging/
Antigravity-AdsPower Login Helper/

